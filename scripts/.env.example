# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# The .env file is listed in .gitignore and will NEVER be committed to git.
# ─────────────────────────────────────────────────────────────────────────────

# NewsAPI key — free at https://newsapi.org/register
# Used to fetch today's top headlines for each category.
NEWS_API_KEY=your_newsapi_key_here

# Anthropic (Claude) API key — get yours at https://console.anthropic.com
# Used to write the 2 original articles per category each day.
# Estimated cost: roughly $0.10–$0.30 per daily run at current rates.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
